---
export const versions = [
  { version: '1.0.0', date: '2024-01-01', description: 'Initial release', details: 'Para hacer esta versión le ofrecimos un femboy como sacrificio a chatgpt' },
  { version: '1.1.0', date: '2024-03-15', description: 'Added new features', details:'Hicimos esta versión mientras jugabamos al teto' },
  { version: '1.2.0', date: '2024-05-20', description: 'Improved performance', details:'Me follé un caterpie' },
  // En un futuro importar como un json, o manejarlo como un .md, veremos dijo el ciego.
];
---

<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Versiones de la Extensión</title>
</head>
<body class="bg-gray-100 text-gray-800">
  <main class="container mx-auto p-6">
    <h1 class="text-3xl font-bold mb-6">Historial de Versiones</h1>
    <div class="relative border-l border-gray-200">
      {versions.map(version => (
        <div class="mb-10 ml-6">
          <span class="flex items-center justify-center w-6 h-6 bg-blue-500 rounded-full -left-3 absolute"></span>
          <div class="p-4 bg-white rounded-lg shadow-lg">
            <a href={`/versions/${version.version}`} class="text-lg font-semibold text-blue-600 hover:underline">{`Versión ${version.version}`}</a>
            <p class="text-sm text-gray-500">{version.date}</p>
            <p class="mt-2">{version.description}</p>
          </div>
        </div>
      ))}
    </div>
  </main>
</body>
</html>
