---

---

<nav class="border-[#550055] border-b-[0.1rem] bg-[#440044] bg-opacity-80">
  <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
    <a href="#" class="flex items-center space-x-3 rtl:space-x-reverse">
      <span class="self-center text-2xl font-semibold whitespace-nowrap dark:text-white">Manga Library</span>
    </a>
    <button data-collapse-toggle="navbar-default" type="button" class="inline-flex items-center p-2 ml-3 text-sm text-[#c9a4c9] rounded-lg md:hidden hover:bg-[#550055] focus:outline-none focus:ring-2 focus:ring-[#aa55aa] dark:text-[#e0b3e0] dark:hover:bg-[#550055] dark:focus:ring-[#aa55aa]" aria-controls="navbar-default" aria-expanded="false">
      <span class="sr-only">Open main menu</span>
      <svg class="w-6 h-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/>
      </svg>    
    </button>
    
    <div class="hidden w-full md:block md:w-auto" id="navbar-default">
      <ul class="flex flex-col md:flex-row md:space-x-8 font-medium rounded-lg md:mt-0 md:border-0">
        <li class="group relative w-max">
          <a href="/" class="block py-2 px-3 md:p-0 rounded">Home</a>
          <span class="absolute -bottom-1 left-1/2 w-0 transition-all h-0.5 bg-purple-600 group-hover:w-3/6"></span>
          <span class="absolute -bottom-1 right-1/2 w-0 transition-all h-0.5 bg-purple-600 group-hover:w-3/6"></span>
        </li>
        <li class="group relative w-max">
          <a href="#" class="block py-2 px-3 md:p-0 rounded">Download</a>
          <span class="absolute -bottom-1 left-1/2 w-0 transition-all h-0.5 bg-purple-600 group-hover:w-3/6"></span>
          <span class="absolute -bottom-1 right-1/2 w-0 transition-all h-0.5 bg-purple-600 group-hover:w-3/6"></span>
        </li>
        <li class="group relative w-max">
          <a href="#" class="block py-2 px-3 md:p-0 rounded">About</a>
          <span class="absolute -bottom-1 left-1/2 w-0 transition-all h-0.5 bg-purple-600 group-hover:w-3/6"></span>
          <span class="absolute -bottom-1 right-1/2 w-0 transition-all h-0.5 bg-purple-600 group-hover:w-3/6"></span>
        </li>
        <li class="group relative w-max">
          <a href="/versions" class="block py-2 px-3 md:p-0 rounded">Versions</a>
          <span class="absolute -bottom-1 left-1/2 w-0 transition-all h-0.5 bg-purple-600 group-hover:w-3/6"></span>
          <span class="absolute -bottom-1 right-1/2 w-0 transition-all h-0.5 bg-purple-600 group-hover:w-3/6"></span>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded',()=>{
    const toggleButton = document.querySelector('[data-collapse-toggle]');
    const navbar = document.getElementById('navbar-default');

    toggleButton.addEventListener('click', function() {
      const isHidden = navbar.classList.contains('hidden');

      if (isHidden) {
        navbar.classList.remove('hidden');
      
      }else{
        navbar.classList.add('hidden')
      }
      })
  })
</script>